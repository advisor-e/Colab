{
  // Project markdown standard — read by both editors and the `lint:md` gate.
  // All correctness/readability rules stay ON. The disabled rules are either a
  // deliberate house style, or newer style-only rules the Node-14-locked linter
  // (markdownlint-cli 0.28.1) cannot enforce — disabling those keeps the editor
  // in step with the enforceable gate instead of showing a phantom standard.
  "default": true,
  "MD013": false,
  "MD049": false,
  "MD050": false,
  "MD060": false
}

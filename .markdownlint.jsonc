{
  // Project markdown standard (for editors + the markdownlint tool).
  // All correctness/readability rules stay ON; only two purely-stylistic rules
  // are disabled because the docs use a deliberate house style:
  //   MD013 — the docs hard-wrap prose at ~95 chars on purpose.
  //   MD060 — tables are kept aligned/readable; the newer pipe-spacing style rule
  //           would otherwise churn every table for no readability gain.
  "default": true,
  "MD013": false,
  "MD060": false
}

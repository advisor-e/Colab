    "restify": "9.1.0",
    "vue": "^2.6.14",
    "vue-i18n": "^8.27.2",
    "vue-router": "^3.5.3",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "7.10.4",
    "@nuxt/friendly-errors-webpack-plugin": "^2.5.2",
    "@nuxtjs/eslint-config": "6.0.1",
    "babel-jest": "^27.5.1",
    "concurrently": "7.6.0",
    "cross-env": "7.0.3",
    "cssnano": "4.1.11",
    "eslint": "7.32.0",
    "jest": "^27.5.1",

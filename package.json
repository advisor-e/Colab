{
  "name": "advisor-collaborate",
  "private": true,
  "engines": {
    "node": "14.15.x"
  },
  "scripts": {
    "prepare": "husky install",
    "check:location": "node scripts/check-run-location.js",
    "predev": "node scripts/check-run-location.js",
    "predev:all": "node scripts/check-run-location.js",
    "prebackend": "node scripts/check-run-location.js",
    "prestart": "node scripts/check-run-location.js",
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "lint": "eslint --ext .js,.vue .",
    "lint:fix": "eslint --ext .js,.vue . --fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --config .markdownlint.jsonc",
    "test": "jest",
    "test:e2e": "playwright test",
    "audit:gate": "node scripts/audit-gate.js",
    "backend": "cross-env ALLOW_DEV_AUTH=true NODE_EXTRA_CA_CERTS=./certs/digicert-bundle.pem node server/restify-server.js",
    "dev:all": "concurrently --names \"nuxt,api\" --prefix-colors \"cyan,green\" \"npm run dev\" \"npm run backend\""
  },
  "dependencies": {
    "buefy": "^0.9.29",
    "bulma": "^0.9.4",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "3.16.0",
    "nuxt": "2.14.0",
    "restify": "9.1.0",
    "vue": "^2.6.14",
    "vue-i18n": "^8.27.2",
    "vue-router": "^3.5.3",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "7.10.4",
    "@nuxt/friendly-errors-webpack-plugin": "^2.5.2",
    "@nuxtjs/eslint-config": "6.0.1",
    "@playwright/test": "1.34.3",
    "@vue/test-utils": "1.3.6",
    "@vue/vue2-jest": "27.0.0",
    "babel-jest": "^27.5.1",
    "concurrently": "7.6.0",
    "cross-env": "7.0.3",
    "cssnano": "4.1.11",
    "eslint": "7.32.0",
    "husky": "^8.0.3",
    "jest": "^27.5.1",
    "markdownlint-cli": "^0.28.1",
    "pug": "^2.0.4",
    "pug-plain-loader": "^1.1.0",
    "vue-template-compiler": "2.7.16"
  }
}

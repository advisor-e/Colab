#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-commit quality gate (CLAUDE.md §Enforcement).
# Runs ESLint + markdownlint + Jest + the dependency-audit gate before every commit.
# The audit gate (scripts/audit-gate.js) blocks on any CRITICAL finding except the
# documented, reviewed build-time allow-list — see design/SECURITY-AUDIT-NOTES.md and
# design/ACTIONS.md P1-AUDIT-GATE.
npm run lint && npm run lint:md && npm test && npm run audit:gate
